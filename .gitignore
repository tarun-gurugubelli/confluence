# ---------------------------------------------------------------------------
# Environment files (commit *.example versions, never the actual values)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python / FastAPI backend
# ---------------------------------------------------------------------------
backend/.venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.python-version

# ---------------------------------------------------------------------------
# AWS SAM build / deploy artifacts
# ---------------------------------------------------------------------------
backend/.aws-sam/
samconfig.toml.local
parameters.local.json

# ---------------------------------------------------------------------------
# Node / Angular frontend
# ---------------------------------------------------------------------------
node_modules/
dist/
out-tsc/
.angular/
.ng/
coverage/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Editors and IDEs
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.history/
*.sublime-workspace
*.sublime-project

# ---------------------------------------------------------------------------
# Operating system
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Build / packaging temp
# ---------------------------------------------------------------------------
tmp/
*.zip
*.tar.gz
